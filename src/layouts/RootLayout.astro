---
import LoadingIndicator from 'astro-loading-indicator/component';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

const { title, description, image } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const defaultTitle = 'Gabriel Castillo | Backend Developer';
const defaultDescription =
  'Backend Developer with 3+ years of experience building scalable REST APIs, microservices architectures, and containerized applications. Proficient in Laravel, NestJS, and Python with hands-on experience in Docker, AWS, CI/CD pipelines, and Linux server administration.';

const pageTitle = title ?? defaultTitle;
const pageDescription = description ?? defaultDescription;
const siteUrl = Astro.site ?? Astro.url;
// Normaliza con barra final para que canonical = og:url = sitemap (GitHub Pages
// sirve las rutas con barra). Evita señales de canonicalización contradictorias.
const pathname = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonical = new URL(pathname, siteUrl).href;
// Las redes exigen URL absoluta para la imagen OG (no sirve la ruta relativa).
const ogImage = new URL(image ?? `${base}og-image.png`, siteUrl).href;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gabriel Castillo',
  url: new URL(base, siteUrl).href,
  jobTitle: 'Backend Developer',
  description: defaultDescription,
  image: ogImage,
  sameAs: [
    'https://github.com/gabo8191',
    'https://linkedin.com/in/gabodev8191',
    'https://twitter.com/gcastillo8191',
  ],
  knowsAbout: [
    'Laravel',
    'NestJS',
    'Python',
    'REST APIs',
    'Microservices',
    'Docker',
    'AWS',
    'PostgreSQL',
  ],
};
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='theme-color' content='#0f0a1a' />
    <link rel='icon' type='image/svg+xml' href={`${base}favicon.svg`} />
    <link rel='canonical' href={canonical} />
    <meta name='generator' content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name='description' content={pageDescription} />

    <meta property='og:url' content={canonical} />
    <meta property='og:type' content='website' />
    <meta property='og:site_name' content='Gabriel Castillo' />
    <meta property='og:locale' content='en_US' />
    <meta property='og:title' content={pageTitle} />
    <meta property='og:description' content={pageDescription} />
    <meta property='og:image' content={ogImage} />
    <meta property='og:image:width' content='1200' />
    <meta property='og:image:height' content='630' />
    <meta property='og:image:alt' content='Gabriel Castillo — Backend Developer' />

    <!-- Twitter Meta Tags -->
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:site' content='@gcastillo8191' />
    <meta name='twitter:creator' content='@gcastillo8191' />
    <meta property='twitter:domain' content='gabo8191.github.io' />
    <meta property='twitter:url' content={canonical} />
    <meta name='twitter:title' content={pageTitle} />
    <meta name='twitter:description' content={pageDescription} />
    <meta name='twitter:image' content={ogImage} />
    <meta name='twitter:image:alt' content='Gabriel Castillo — Backend Developer' />

    <script
      type='application/ld+json'
      set:html={JSON.stringify(personLd)}
    />

    <Font cssVariable='--font-geist' preload />
    <ClientRouter />
    <LoadingIndicator color='#f4f4f5' height='2px' />
  </head>
  <body class='font-sans min-h-screen bg-zinc-900'>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
