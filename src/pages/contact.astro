---
import ExternalLink from '../components/external-link.astro';
import H1 from '../components/h1.astro';
import InfoLayout from '../layouts/InfoLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<InfoLayout>
  <div
    class='p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh flex flex-col justify-between'
  >
    <div>
      <H1>Let's Connect</H1>
      <p
        class='mt-4 md:mt-8 lg:mt-12 text-xl xl:text-2xl text-zinc-400 text-balance'
      >
        Interested in working together? I'm open to new opportunities in backend
        development and DevOps roles.
      </p>

      <div class='mt-6 sm:mt-12 flex flex-col gap-1'>
        <a
          href='mailto:gabo8191@gmail.com'
          class='mb-8 w-fit group flex items-center gap-1 text-base lg:text-xl text-zinc-400 hover:text-zinc-50'
        >
          gabo8191@gmail.com
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='-rotate-45 group-hover:rotate-0 transition-all duration-300 ease-in-out'
            width='24'
            height='24'
            viewBox='0 0 24 24'
          >
            <title>Arrow Icon</title>
            <path
              fill='currentColor'
              d='M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2S2 6.477 2 12s4.477 10 10 10'
              opacity='.5'></path>
            <path
              fill='currentColor'
              d='M13.53 8.47a.75.75 0 1 0-1.06 1.06l1.72 1.72H8a.75.75 0 0 0 0 1.5h6.19l-1.72 1.72a.75.75 0 1 0 1.06 1.06l3-3a.75.75 0 0 0 0-1.06z'
            ></path>
          </svg>
        </a>

        <ExternalLink href='https://github.com/gabo8191'>GitHub</ExternalLink>
        <ExternalLink href='https://linkedin.com/in/gabodev8191/'
          >LinkedIn</ExternalLink
        >
        <ExternalLink href='https://twitter.com/@gcastillo8191'
          >Twitter</ExternalLink
        >
      </div>

      <div class='mt-8 sm:mt-12'>
        <h2 class='text-lg text-zinc-300 mb-4'>Download my CV</h2>
        <div class='flex flex-wrap gap-4'>
          <a
            href={`${base}cv-en.pdf`}
            target='_blank'
            class='inline-flex items-center gap-2 px-4 py-2 text-sm text-zinc-900 bg-zinc-100 hover:bg-white rounded-full transition-all'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-4 h-4'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            >
              <path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4'></path>
              <polyline points='7 10 12 15 17 10'></polyline>
              <line x1='12' y1='15' x2='12' y2='3'></line>
            </svg>
            <span>English CV</span>
          </a>
          <a
            href={`${base}cv-es.pdf`}
            target='_blank'
            class='inline-flex items-center gap-2 px-4 py-2 text-sm text-zinc-300 border border-zinc-600 hover:border-zinc-400 hover:text-white rounded-full transition-all'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-4 h-4'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            >
              <path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4'></path>
              <polyline points='7 10 12 15 17 10'></polyline>
              <line x1='12' y1='15' x2='12' y2='3'></line>
            </svg>
            <span>Spanish CV</span>
          </a>
        </div>
      </div>
    </div>

    <div>
      <p class='text-base text-zinc-500'>Tunja, Boyacá</p>
      <p class='text-base text-zinc-500'>Colombia</p>
      <p class='text-base text-zinc-500 mt-2'>+57 318 8708253</p>
    </div>
  </div>
</InfoLayout>
