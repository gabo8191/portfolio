---
import AvailableForWork from '../components/available.astro';
import GrainGradientBackground from '../components/grain-gradient-background';
import H1 from '../components/h1.astro';
import Link from '../components/link.astro';
import Navigation from '../components/navigation';
import RootLayout from '../layouts/RootLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<RootLayout
  title='Gabriel Castillo | Backend Developer'
  description='Backend Developer building scalable REST APIs, microservices and containerized apps with Laravel, NestJS and Python. Experienced with Docker, AWS and CI/CD.'
>
  <main id='main-content'>
    <div
      class='group relative w-full min-h-dvh flex items-center justify-center'
    >
      <div class='absolute w-full h-dvh -z-10'>
        <GrainGradientBackground
          colors={['#7c3aed', '#a855f7', '#c084fc', '#6366f1', '#818cf8']}
          colorBack='#0f0a1a'
          softness={0.6}
          intensity={0.4}
          noise={0.2}
          shape='corners'
          speed={0.6}
          client:idle
        />
      </div>

      <div
        class='p-4 sm:p-8 absolute w-full h-dvh flex flex-col justify-between z-10'
      >
        <div>
          <H1 size='large'> Gabriel <br /> Castillo </H1>
        </div>

        <div>
          <AvailableForWork className='py-4' />
          <div
            class='mb-2 sm:mb-4 flex flex-wrap items-center justify-between gap-4'
          >
            <div class='flex flex-wrap items-center gap-4'>
              <a
                href={`${base}cv-en.pdf`}
                target='_blank'
                rel='noopener noreferrer'
                class='w-fit text-base sm:text-2xl px-5 py-2 rounded-full transition-all duration-300 ease-in-out whitespace-nowrap text-zinc-900 bg-zinc-100 hover:outline-2 focus-visible:outline-2 outline-offset-2 outline-zinc-100'
                >Download CV</a
              >
              <Link href='/projects' variant='secondary'>View Projects</Link>
            </div>

            <Navigation base={base} client:load>
              <Link href='/about' variant='secondary'>About</Link>
              <Link href='/contact' variant='secondary'>Contact</Link>
            </Navigation>
          </div>
        </div>
      </div>
    </div>
  </main>
</RootLayout>
